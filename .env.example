# Секретный ключ для подписи сессий и шифрования сообщений
# Сгенерировать: python -c "import secrets; print(f'SECRET_KEY={secrets.token_hex(32)}')"
SECRET_KEY=your-secret-key-here

# Sentry DSN for error tracking (optional — omit to disable)
# SENTRY_DSN=https://key@o123.ingest.de.sentry.io/project

# Widget API keys (optional — omit = widget type won't work for anyone)
# Last.fm API key — get one at https://www.last.fm/api/account/create
# LASTFM_API_KEY=your_lastfm_api_key
# Shared secret (не используется — только API key нужен для чтения)
# Steam API key — get one at https://steamcommunity.com/dev/apikey
# STEAM_API_KEY=your_steam_api_key
